# IBM watsonx.ai Credentials
# Copy this file to .env and fill in your actual credentials

# Your IBM Cloud API Key (required)
IBM_API_KEY=your_ibm_api_key_here

# IBM watsonx.ai Project ID (required)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM watsonx.ai URL (default: Dallas region)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Flask Secret Key (change this to a random string in production)
SECRET_KEY=careercraft-secret-key-change-in-production

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=True

# Application Port
PORT=5000
